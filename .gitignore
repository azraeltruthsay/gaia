# ============================================
# GAIA Project .gitignore
# ============================================

# --- Large directories / binaries ---
/archive/
gaia-models/
google-cloud-sdk/
artifacts/
GAIA_Condensed_flat/

# --- Backup directories (from promote_candidate.sh) ---
*.bak/

# --- Virtual environments ---
.venv/
venv_notebooklm/

# --- Environment / secrets ---
.env
.env.*
*.key
*.ke
*.pem
wireguard_setup/

# --- Audio inbox (user audio files) ---
audio_inbox/

# --- Logs ---
logs/
*.log
build_log.txt
mcp_logs.txt
latest_test.txt

# --- Temp files ---
tmp/
tmp_*.py

# --- Video / large media files ---
*.mp4
*.mkv
*.avi
*.mov

# --- Binaries / large standalone files ---
llama_cpp
inspect
sys
logging
*.tar.gz
*.tar

# --- Generated output ---
gaia_tree.txt
nvidia_pre_debug.txt
nvidia_post_debug.txt

# --- Tools / config not tracked ---
tools/
.claude/
.gemini/

# --- Standalone root files (not part of SOA services) ---
Geppitti Persona & Interaction Overview
notebooklm_sync.py
start_notebooklm_sync.sh
setup_models.py
count_file_types.sh
create_flat_representation.sh
flatten_soa.sh
interactive_gaia_start.sh
run_dnd_test.sh
test_gaia_core_imports.sh
prompt
recall

# --- Knowledge exclusions (DND project) ---
knowledge/dnd_campaign/
knowledge/projects/dnd-campaign/
knowledge/logs/

# --- Runtime / session data ---
**/sessions.json
app/shared/
**/last_activity.timestamp
**/final_prompt_for_review.json
**/session_vectors/
**/smoke-test-*.json
**/test-sess.json

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Test artifacts (MagicMock from pytest) ---
**/MagicMock/

# --- Samvega emotional state logs (runtime data) ---
knowledge/samvega/

# --- Generated curricula (regenerate via build_curriculum.py) ---
knowledge/curricula/

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/

# --- Node ---
node_modules/
