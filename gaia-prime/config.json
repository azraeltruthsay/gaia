  "STUDY_MODE": {
    "enabled": true,
    "base_model_path": "/models/Huihui-Qwen3-8B-abliterated-v2",
    "max_training_time_seconds": 600,
    "max_training_samples": 1000,
    "max_training_content_kb": 500,
    "qlora_config": {
      "load_in_4bit": true,
      "bnb_4bit_compute_dtype": "bfloat16",
      "bnb_4bit_quant_type": "nf4",
      "bnb_4bit_use_double_quant": true,
      "lora_r": 4,
      "lora_alpha": 8,
      "lora_dropout": 0.05,
      "target_modules": [
        "q_proj",
        "v_proj"
      ],
      "batch_size": 1,
      "gradient_accumulation_steps": 4,
      "gradient_checkpointing": true,
      "learning_rate": 0.0002,
      "max_steps": 300,
      "warmup_steps": 10
    },
    "governance": {
      "forbidden_patterns": [
        "ignore previous instructions",
        "you are now",
        "forget your training",
        "forget your values",
        "forget your ethics"
      ],
      "max_session_adapters": 3,
      "max_user_adapters": 10
